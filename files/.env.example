# Copy this to .env and fill in your values

ANTHROPIC_API_KEY=sk-ant-...

# PostgreSQL connection string
DATABASE_URL=postgresql://user:password@localhost:5432/privacy_cases

# Limit how many PDFs to process per run (saves credits). Default 10 for testing.
# To process ALL PDFs in inbox, remove or comment out MAX_PDFS.
MAX_PDFS=10

# Folder paths (defaults: files/inbox, files/processed, files/errors when using agent.py path)
# Override with absolute paths if needed
# WATCH_DIR=/path/to/inbox
# DONE_DIR=/path/to/processed
# ERROR_DIR=/path/to/errors

# Local PDF server URL — serve files/processed/ with: cd files/processed && python3 -m http.server 8765
# Then set this to expose PDF download links in the frontend.
# Leave unset to disable PDF links.
# PDF_SERVER_URL=http://localhost:8765
